{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    ":configMigration"
  ],

  "baseBranchPatterns": ["dev"],

  "timezone": "Europe/Helsinki",
  "schedule": ["* 0-6 * * 1"],

  "prConcurrentLimit": 3,

  "flux": {
    "managerFilePatterns": [
      "kubernetes/infrastructure/controllers/**/*.{yaml,yml}",
      "kubernetes/apps/**/*.{yaml,yml}"
    ]
  },
  
  "packageRules": [
    {
      "description": "Group infrastructure updates",
      "matchFileNames": [
        "kubernetes/infrastructure/base/**",
        "kubernetes/infrastructure/controllers/**",
        "kubernetes/infrastructure/configs/**"
      ],
      "groupName": "Infrastructure updates",
      "addLabels": ["infrastructure"],
      "prPriority": 10
    },
    {
      "description": "Group application updates",
      "matchFileNames": ["kubernetes/apps/**"],
      "groupName": "Application updates",
      "addLabels": ["apps"],
      "prPriority": 15
    },
    {
      "description": "Group GitHub Actions workflow updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions updates",
      "addLabels": ["github-actions"],
      "prPriority": 2
    },

    {
      "description": "Keep major version updates separate",
      "matchUpdateTypes": ["major"],
      "groupName": null,
      "addLabels": ["major-update"]
    },

    {
      "description": "Keep External Secrets Operator minor updates separate",
      "matchPackageNames": ["external-secrets"],
      "matchUpdateTypes": ["minor"],
      "separateMultipleMinor": true,
      "groupName": null,
      "addLabels": ["minor-update"],
      "prPriority": 8
    }
  ]
}
