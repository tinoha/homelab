#cloud-config
package_reboot_if_required: true
package_update: true
package_upgrade: true
packages:
  - qemu-guest-agent
timezone: Europe/Helsinki
keyboard:
  layout: fi

runcmd:
  - systemctl enable  qemu-guest-agent
  - systemctl start   qemu-guest-agent

password: password
chpasswd:
  expire: False
ssh_pwauth: True

users:
  - default
  - name: tino
    shell: /bin/bash
    gecos: "Tino H"
    homedir: /home/tino
    groups: users
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - ssh-rsa 
    ssh_pwauth: True
